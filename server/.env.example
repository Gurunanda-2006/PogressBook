# Server Environment Variables
# Copy this file to .env and fill in your values

# Google Service Account (paste the ENTIRE JSON contents on one line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Spreadsheet ID (from the sheet URL)
SPREADSHEET_ID=

# Google OAuth Client (for "Sign in with Google" token verification)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# JWT secret for signing session tokens (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=

# Server port
PORT=3000

# Frontend URL(s) for CORS. Separate multiple origins with commas.
CLIENT_URL=http://localhost:5173
